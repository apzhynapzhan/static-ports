(package ; hello, world!!!
  (name "hello")
  (version "1.0.0")
  (category "utils")
  (description "hello world")
  (source "")
  (sha256 "")
  (binary "hello")
  (install "/usr/bin/hello")
  (build
  (env "CC" "clang")
  (run "sh" "-c"
    "echo '#include <stdio.h>\nint main(){puts(\"hello world\");return 0;}' > hello.c && \
     clang --target=x86_64-linux-musl -static -o hello hello.c"))